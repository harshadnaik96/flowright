# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flowright:flowright@localhost:5432/flowright

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
WEB_URL=http://localhost:3000

# ─── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Used to encrypt auth credentials at rest.
ENCRYPTION_KEY=change-this-to-a-long-random-secret-key

# ─── Crawler ──────────────────────────────────────────────────────────────────
# Hours before SSO storage state is considered expired (default: 8)
SSO_SESSION_TTL_HOURS=8

# ─── Storage ──────────────────────────────────────────────────────────────────
# Screenshots from test runs. If SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are
# set, screenshots upload to Supabase Storage and survive server restarts.
# Otherwise they're written to SCREENSHOT_DIR on the local filesystem (lost on
# restart, not shareable across instances).
SUPABASE_URL=https://coqhfxyekzhefpwoegux.supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNvcWhmeHlla3poZWZwd29lZ3V4Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODIwMjE3OSwiZXhwIjoyMDkzNzc4MTc5fQ.5kZy_FjUWo4m_-D0pAhga3ctLQMD0Ywoz0xK-T9ah0U
SUPABASE_BUCKET=flowright-runs
SCREENSHOT_DIR=/tmp/flowright-runs

