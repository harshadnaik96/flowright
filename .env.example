# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flowright:flowright@localhost:5432/flowright

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
WEB_URL=http://localhost:3000

# ─── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Used to encrypt auth credentials at rest.
ENCRYPTION_KEY=change-this-to-a-long-random-secret-key

# ─── Crawler ──────────────────────────────────────────────────────────────────
# Hours before SSO storage state is considered expired (default: 8)
SSO_SESSION_TTL_HOURS=8

# ─── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
