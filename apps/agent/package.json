{
  "name": "@flowright/agent",
  "version": "0.1.0",
  "private": true,
  "description": "Flowright local agent — runs Maestro tests on the tester's machine",
  "scripts": {
    "build": "tsc",
    "bundle": "pnpm build && pkg dist/index.js --targets node18-macos-arm64,node18-macos-x64,node18-linux-x64 --output bin/flowright-agent",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": ["node18-macos-arm64", "node18-macos-x64", "node18-linux-x64"],
    "outputPath": "bin"
  }
}
